# common.env.example
#
# Copy to common.env and fill in your values.
# common.env is gitignored — safe to store credentials here locally.
#
# scripts/run.sh sources this file automatically when present.
# You can also source it manually before running Terraform directly:
#   source common.env && cd terraform && terraform apply -parallelism=1

# ── Conjur provider credentials ──────────────────────────────
export CONJUR_TENANT="mycompany"

# Derived from CONJUR_TENANT by run.sh, but set explicitly here
# so `source common.env` also works when running Terraform directly.
export CONJUR_APPLIANCE_URL="https://${CONJUR_TENANT}.secretsmgr.cyberark.cloud/api"
export CONJUR_ACCOUNT="conjur"

# ── Terraform variables ───────────────────────────────────────
export TF_VAR_conjur_tenant="${CONJUR_TENANT}"
export TF_VAR_swa_resource_prefix="swa-demo"
export TF_VAR_swa_oidc_issuer_url="https://mycompany.my.workloads.cyberark.cloud"
export TF_VAR_swa_nodegroup_name="swa-demo-nodegroup"
export TF_VAR_spiffe_subject="swa-demo-nodegroup"
export TF_VAR_conjur_jwt_audience="conjur"

# Secret values — update these to push real credentials
export TF_VAR_openweather_api_key="FAKE-OPENWEATHER-API-KEY"
export TF_VAR_timezone_token="FAKE-TIMEZONE-TOKEN"
