# common.env.example
#
# Copy to common.env and fill in your values.
# common.env is gitignored, so it won't be committed to the repo.
#
# Two Terraform workspaces — two identities:
#
#   admin-setup / admin-teardown
#     Use the active `conjur login` CLI session.
#     No API key needed here; the conjur CLI handles authentication.
#
#   plan / create
#     Use the automation workload host API key below.
#     Run `admin-setup` first — it creates the policy branch and grants
#     the workload host access to secrets within it.

# ── Conjur Cloud connection ───────────────────────────────────
export CONJUR_TENANT="my-tenant"
export CONJUR_APPLIANCE_URL="https://${CONJUR_TENANT}.secretsmgr.cyberark.cloud/api"
export CONJUR_ACCOUNT="conjur"

# ── Automation workload credentials ──────────────────────────
# The automation workspace (plan / create) authenticates as a workload host.
# This host must have read/update/execute on secrets in the managed branch —
# admin-setup creates the branch and grants these privileges automatically.
#
# Get the host login:   conjur whoami  (when logged in as the host, or check policy)
# Get the API key:      conjur host rotate-api-key -i <host-id>
export TF_VAR_conjur_login="host/data/my-workload"
export TF_VAR_conjur_api_key="your-workload-api-key-here"

# ── Local provider build (optional) ──────────────────────────
# Set this to your local clone of the terraform-provider-conjur fork if you
# need a fix that has not yet been published to the Terraform Registry.
# Run `./scripts/conjur-tf.sh build-provider` to compile the binary.
# Leave unset to use the published cyberark/conjur provider instead.
export CONJUR_PROVIDER_SRC_DIR="${HOME}/sandbox/GitHub/terraform-provider-conjur"

# ── Terraform variables ───────────────────────────────────────
export TF_VAR_conjur_tenant="${CONJUR_TENANT}"
export TF_VAR_conjur_resource_prefix="my-test001"

# Full host ID of the automation workload — used by admin-setup to grant
# read/update/execute on secrets in the managed branch.
export TF_VAR_conjur_workload_host="data/my-workload"

# Secret values — update these to push real credentials
export TF_VAR_openweather_api_key="FAKE-OPENWEATHER-API-KEY"
export TF_VAR_timezone_token="FAKE-TIMEZONE-TOKEN"
