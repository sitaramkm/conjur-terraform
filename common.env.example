# common.env.example
#
# Copy to common.env and fill in your values.
# common.env is gitignored, so it won't be committed to the repo.
#

# ── Conjur provider credentials ──────────────────────────────
export CONJUR_TENANT="my-tenant"

export CONJUR_APPLIANCE_URL="https://${CONJUR_TENANT}.secretsmgr.cyberark.cloud/api"
export CONJUR_ACCOUNT="conjur"

# ── Local provider build ──────────────────────────────────────
# Path to your local clone of the terraform-provider-conjur fork.
# Used by scripts/conjur-tf.sh to compile the provider binary.
export CONJUR_PROVIDER_SRC_DIR="${HOME}/sandbox/GitHub/terraform-provider-conjur"

# ── Terraform variables ───────────────────────────────────────
export TF_VAR_conjur_tenant="${CONJUR_TENANT}"
export TF_VAR_conjur_resource_prefix="my-test001"
export TF_VAR_conjur_oidc_issuer_url="https://mycompany.my.workloads.cyberark.cloud"
export TF_VAR_conjur_trust_domain_name="dev-workloads.io"
export TF_VAR_conjur_nodegroup_name="${TF_VAR_conjur_resource_prefix}-nodegroup"
export TF_VAR_spiffe_subject="spiffe://${TF_VAR_conjur_trust_domain_name}/${TF_VAR_conjur_nodegroup_name}/workload"
export TF_VAR_conjur_jwt_audience="conjur"

# Secret values — update these to push real credentials
export TF_VAR_openweather_api_key="FAKE-OPENWEATHER-API-KEY"
export TF_VAR_timezone_token="FAKE-TIMEZONE-TOKEN"
